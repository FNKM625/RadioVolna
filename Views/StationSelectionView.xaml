<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:helpers="clr-namespace:RadioVolna.Resources"
             x:Class="RadioVolna.Views.StationSelectionView">

    <Grid BackgroundColor="#CC000000"
          Padding="20">
        <Border BackgroundColor="{AppThemeBinding Light={StaticResource TextDark}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                VerticalOptions="Center"
                HeightRequest="550">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Grid RowDefinitions="Auto, Auto, *, Auto"
                  Padding="20">

                <Label Grid.Row="0"
                       Text="{helpers:Translate MsgSelectStation}"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10"/>

                <HorizontalStackLayout Grid.Row="1"
                                       HorizontalOptions="Center"
                                       Spacing="10"
                                       Margin="0,0,0,15">
                    <Label Text="{helpers:Translate LabelDeleteMode}"
                           VerticalOptions="Center"
                           TextColor="Gray"
                           FontSize="14"/>
                    <Switch x:Name="EditModeSwitch"/>
                </HorizontalStackLayout>

                <CollectionView Grid.Row="2"
                                x:Name="StationsList"
                                SelectionMode="Single"
                                SelectionChanged="OnStationSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Stroke="Transparent"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLightD}, Dark={StaticResource CardDarkL}}"
                                    Padding="10"
                                    Margin="0,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="Auto, *, Auto"
                                      ColumnSpacing="12">

                                    <Grid Grid.Column="0"
                                          WidthRequest="40"
                                          HeightRequest="40"
                                          VerticalOptions="Center">

                                        <Label Text="{Binding DisplayEmoji}"
                                               FontSize="24"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>

                                        <Image Source="{Binding DisplayFavicon}"
                                               WidthRequest="40"
                                               HeightRequest="40"
                                               Aspect="AspectFit"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Image.Clip>
                                                <RoundRectangleGeometry CornerRadius="8"
                                                                        Rect="0,0,40,40"/>
                                            </Image.Clip>
                                        </Image>
                                    </Grid>

                                    <Label Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                                           FontSize="16"
                                           VerticalOptions="Center"/>

                                    <ContentView Grid.Column="2"
                                                 VerticalOptions="Center">
                                        <Grid>
                                            <Button Text="♡"
                                                    FontSize="22"
                                                    BackgroundColor="Transparent"
                                                    TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                                                    Clicked="OnFavoriteClicked"
                                                    CommandParameter="{Binding .}">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding IsFavorite}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="❤"/>
                                                        <Setter Property="TextColor"
                                                                Value="#FF0000"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding Source={x:Reference EditModeSwitch}, Path=IsToggled}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="False"/>
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>

                                            <Button Text="🗑️"
                                                    FontSize="18"
                                                    BackgroundColor="Transparent"
                                                    TextColor="#FF5555"
                                                    IsVisible="False"
                                                    Clicked="OnDeleteClicked"
                                                    CommandParameter="{Binding .}">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button"
                                                                 Binding="{Binding Source={x:Reference EditModeSwitch}, Path=IsToggled}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible"
                                                                Value="True"/>
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </Grid>
                                    </ContentView>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Grid.Row="3"
                        Text="{helpers:Translate DialogCancel}"
                        Clicked="OnCloseListClicked"
                        BackgroundColor="Transparent"
                        TextColor="#FF5555"
                        Margin="0,15,0,0"/>
            </Grid>
        </Border>
    </Grid>
</ContentView>
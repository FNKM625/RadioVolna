<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioVolna.Views.AddStationMenuView"
             xmlns:helpers="clr-namespace:RadioVolna.Resources"
             x:Name="this">

    <Grid IsVisible="{Binding IsOpen, Source={x:Reference this}}"
          BackgroundColor="#CC000000"
          Padding="20">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCancelClicked"/>
        </Grid.GestureRecognizers>

        <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="340"
                Padding="20">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWindowContentTapped"/>
            </Border.GestureRecognizers>

            <VerticalStackLayout Spacing="14">
                <Label Text="{helpers:Translate TitleAddStation}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Button Text="{helpers:Translate BtnAddCustom}"
                        Clicked="OnAddCustomClicked"/>
                <Button Text="{helpers:Translate BtnSearch}"
                        Clicked="OnSearchClicked"/>
                <Button Text="{helpers:Translate DialogCancel}"
                        Clicked="OnCancelClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
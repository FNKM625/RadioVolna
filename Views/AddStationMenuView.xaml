<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioVolna.Views.AddStationMenuView"
             x:Name="this">

    <Grid IsVisible="{Binding IsOpen, Source={x:Reference this}}"
          BackgroundColor="#CC000000"
          Padding="20">

        <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="340"
                Padding="20">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="14">
                <Label Text="Dodaj stację"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />

                <Button Text="Dodaj własną"
                        Clicked="OnAddCustomClicked" />

                <Button Text="Wyszukaj"
                        Clicked="OnSearchClicked" />

                <Button Text="Anuluj"
                        Clicked="OnCancelClicked" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
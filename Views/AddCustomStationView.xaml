<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioVolna.Views.AddCustomStationView"
             xmlns:helpers="clr-namespace:RadioVolna.Resources"
             x:Name="this">

    <Grid IsVisible="{Binding IsOpen, Source={x:Reference this}}"
          BackgroundColor="#CC000000"
          Padding="20">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCancelClicked"/>
        </Grid.GestureRecognizers>
        <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="360"
                Padding="20">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnWindowContentTapped"/>
            </Border.GestureRecognizers>

            <VerticalStackLayout Spacing="14">
                <Label Text="{helpers:Translate TitleAddCustomStation}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Entry x:Name="NameEntry"
                       Placeholder="{helpers:Translate PlaceholderStationName}"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Entry x:Name="UrlEntry"
                       Placeholder="{helpers:Translate PlaceholderStreamUrl}"
                       Keyboard="Url"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Entry x:Name="EmojiEntry"
                       Placeholder="{helpers:Translate PlaceholderEmoji}"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Grid ColumnDefinitions="Auto,*,*"
                      ColumnSpacing="10"
                      Margin="0,10,0,0">
                    <Button Grid.Column="0"
                            Text="▶"
                            WidthRequest="50"
                            Clicked="OnPreviewClicked"/>

                    <Button Grid.Column="1"
                            Text="{helpers:Translate BtnAdd}"
                            BackgroundColor="#03DAC6"
                            TextColor="Black"
                            Clicked="OnSaveClicked"/>

                    <Button Grid.Column="2"
                            Text="{helpers:Translate DialogCancel}"
                            BackgroundColor="Transparent"
                            TextColor="#FF5555"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:RadioVolna.Views"
             xmlns:helpers="clr-namespace:RadioVolna.Resources"
             x:Class="RadioVolna.MainPage"
             BackgroundColor="{AppThemeBinding Light={StaticResource BgLight}, Dark={StaticResource BgDark}}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <VerticalStackLayout Grid.Row="0"
                             Spacing="10"
                             Padding="30,40,30,10">
            <Label Text="{helpers:Translate AppName}"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                   HorizontalOptions="Center"/>

            <Label x:Name="CurrentStationLabel"
                   Text="{helpers:Translate MsgSelectStation}"
                   TextColor="#03DAC6"
                   FontSize="22"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <Label x:Name="StatusLabel"
                   Text="{helpers:Translate StatusReady}"
                   TextColor="Gray"
                   FontSize="14"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <Button Grid.Row="0"
                Text="⚙️"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="Gray"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,35,15,0"
                Clicked="OnSettingsClicked"/>

        <Button Grid.Row="0"
                Text="➕"
                FontSize="24"
                BackgroundColor="Transparent"
                TextColor="Gray"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="15,35,0,0"
                Clicked="OnOpenAddStationMenuClicked"/>

        <Image Grid.Row="1"
               Source="logo_radio_volna.png"
               Aspect="AspectFit"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               Margin="40"/>

        <VerticalStackLayout Grid.Row="2"
                             Spacing="20"
                             Padding="30,10,30,40">

            <Button Text="{helpers:Translate BtnStationList}"
                    Clicked="OnOpenListClicked"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                    HeightRequest="60"
                    CornerRadius="30"/>

            <Button x:Name="PlayPauseBtn"
                    Text="{helpers:Translate BtnResume}"
                    Clicked="OnPlayPauseClicked"
                    BackgroundColor="#6200EE"
                    TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                    HeightRequest="60"
                    CornerRadius="30"
                    IsEnabled="False"/>

            <Button Text="{helpers:Translate BtnExit}"
                    Clicked="OnExitClicked"
                    BackgroundColor="{AppThemeBinding Light={StaticResource BCLight}, Dark={StaticResource BCDardk}}"
                    TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                    HeightRequest="60"
                    CornerRadius="30"/>
        </VerticalStackLayout>

        <views:StationSelectionView x:Name="StationSelectionOverlay"
                                    Grid.RowSpan="3"
                                    IsVisible="False"
                                    StationSelected="OnStationSelectionView_StationSelected"
                                    FavoriteClicked="OnStationSelectionView_FavoriteClicked"
                                    CloseRequested="OnStationSelectionView_CloseRequested"
                                    DeleteClicked="OnStationSelectionView_DeleteClicked"/>

        <Grid x:Name="SettingsOverlayContainer"
              IsVisible="False"
              Grid.RowSpan="3">
            <views:SettingsView
                CloseRequested="OnCloseSettingsClicked"
                AutostartRequested="OnAutostartOptionClicked"
                AboutRequested="OnAboutClicked"/>
        </Grid>

        <Grid x:Name="AutoStartOverlay"
              Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#CC000000"
              Padding="20">

            <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                    StrokeThickness="0"
                    VerticalOptions="Center"
                    HeightRequest="500">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto, Auto, *, Auto"
                      RowSpacing="10"
                      Padding="20">

                    <Label Grid.Row="0"
                           Text="{helpers:Translate LabelAutoStartStation}"
                           TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                           FontSize="14"
                           HorizontalOptions="Center"/>

                    <Label Grid.Row="1"
                           x:Name="CurrentAutoStartLabel"
                           Text="{helpers:Translate MsgNoStationSelected}"
                           TextColor="#03DAC6"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <CollectionView Grid.Row="2"
                                    x:Name="AutoStartList"
                                    SelectionMode="Single"
                                    SelectionChanged="OnAutoStartStationSelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="Transparent"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource CardLightD}, Dark={StaticResource CardDarkL}}"
                                        Padding="15"
                                        Margin="0,5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="❤"
                                               TextColor="#FF0000"
                                               IsVisible="{Binding IsFavorite}"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Button Grid.Row="3"
                            FontSize="18"
                            Text="{helpers:Translate DialogCancel}"
                            Clicked="OnCloseAutoStartClicked"
                            BackgroundColor="Transparent"
                            TextColor="#FF5555"
                            Margin="0,10,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="NotificationBadge"
                VerticalOptions="End"
                HorizontalOptions="Center"
                Margin="0,0,0,80"
                Padding="15,10"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeShape="RoundRectangle 20"
                Opacity="0"
                InputTransparent="True"
                IsVisible="False">

            <Label x:Name="NotificationLabel"
                   Text="{helpers:Translate MsgAddedToAutoStart}"
                   TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                   FontSize="14"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
        </Border>

        <views:AddStationMenuView x:Name="AddStationMenuOverlay"
                                  Grid.RowSpan="3"
                                  IsOpen="False"
                                  AddCustomClicked="OnAddCustomStationClicked"
                                  SearchClicked="OnSearchStationClicked"/>

        <views:AddCustomStationView x:Name="AddCustomStationOverlay"
                                    Grid.RowSpan="3"
                                    IsOpen="False"
                                    PreviewClicked="OnCustomStationPreviewClicked"
                                    SaveClicked="OnCustomStationSaveClicked"
                                    CancelClicked="OnCustomStationCancelClicked"/>

        <views:SearchStationView x:Name="SearchStationFilterOverlay"
                                 Grid.RowSpan="3"
                                 IsOpen="False"
                                 SearchClicked="OnExecuteApiSearchClicked"
                                 CancelClicked="OnCancelApiSearchClicked"/>

        <views:SearchStationResultsView x:Name="SearchStationResultsOverlay"
                                        Grid.RowSpan="3"
                                        IsOpen="False"
                                        PreviewClicked="OnSearchResultPreviewClicked"
                                        AddClicked="OnSearchResultAddClicked"
                                        CloseClicked="OnSearchResultsCloseClicked"/>

    </Grid>
</ContentPage>
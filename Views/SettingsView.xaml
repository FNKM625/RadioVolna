<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioVolna.Views.SettingsView"
             BackgroundColor="#CC000000">

    <Border BackgroundColor="#252525"
            StrokeThickness="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="300">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20"/>
        </Border.StrokeShape>

        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Ustawienia"
                   TextColor="White"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,10"/>

            <Button Text="Dodaj stację do autostartu"
                    Clicked="OnAutostartClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    CornerRadius="10"/>

            <Button Text="🌍 Zmień język"
                    Clicked="OnLanguageClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    CornerRadius="10"/>

            <Button Text="🎨 Zmień motyw"
                    Clicked="OnThemeClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    CornerRadius="10"/>

            <Button Text="ℹ️ O aplikacji"
                    Clicked="OnAboutClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    Margin="0,10,0,0"/>

            <Button Text="Zamknij"
                    Clicked="OnCloseClicked"
                    BackgroundColor="Transparent"
                    TextColor="#FF5555"
                    Margin="0,5,0,0"/>
        </VerticalStackLayout>
    </Border>
</ContentView>
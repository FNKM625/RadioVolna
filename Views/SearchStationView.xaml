<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioVolna.Views.SearchStationView"
             x:Name="this">

    <Grid IsVisible="{Binding IsOpen, Source={x:Reference this}}"
          BackgroundColor="#CC000000"
          Padding="20">

        <Border BackgroundColor="{AppThemeBinding Light={StaticResource CardLight}, Dark={StaticResource CardDark}}"
                StrokeThickness="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="360"
                Padding="20">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="14">

                <Label Text="Wyszukaj stacje"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"
                       HorizontalOptions="Center"/>

                <Entry x:Name="NameEntry"
                       Placeholder="Nazwa / słowo kluczowe"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Entry x:Name="CountryEntry"
                       Placeholder="Państwo (np. Poland) lub kod (PL)"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Entry x:Name="TagsEntry"
                       Placeholder="Tagi, np. rock, news"
                       TextColor="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}"/>

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10"
                      Margin="0,10,0,0">
                    <Button Grid.Column="0"
                            Text="Szukaj"
                            BackgroundColor="#03DAC6"
                            TextColor="Black"
                            Clicked="OnSearchClicked"/>

                    <Button Grid.Column="1"
                            Text="Anuluj"
                            BackgroundColor="Transparent"
                            TextColor="#FF5555"
                            Clicked="OnCancelClicked"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>